    "firebase-functions": "^6.0.0",
    "stripe":             "^18.0.0",
    "resend":             "^4.0.0"
  },
  "devDependencies": {
    "@types/node":         "^20.0.0",
    "typescript":          "^5.0.0",
    "firebase-functions-test": "^3.0.0"
  }
}
